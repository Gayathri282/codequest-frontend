# Dependencies
node_modules/
**/node_modules/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
!**/.env.example

# Build outputs
dist/
build/
**/dist/
**/build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Uploads (user-generated content)
backend/uploads/*
!backend/uploads/.gitkeep

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Package manager locks (keep package-lock.json, ignore yarn.lock if not used)
yarn.lock
